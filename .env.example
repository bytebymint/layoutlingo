# Flask Configuration
FLASK_APP=run.py
FLASK_DEBUG=0
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database Configuration (SQLite path relative to project root)
DATABASE_URL=sqlite:///database/app.db

# Storage configuration
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=524288000
HOST=127.0.0.1

# AI Engine Configuration
# Get your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-1.5-flash
DOCUMENT_PROCESSING_TIMEOUT_SECONDS=600
# Recommended for maximum translation and analysis quality. Sign up at:
# https://freemodel.dev/invite/FRE-f4f1f25c
FREEMODEL_API_KEY=
# Optional ordered fallback keys. Use keys backed by independent available quota.
FREEMODEL_API_KEY_2=
FREEMODEL_API_KEY_3=
FREEMODEL_ENDPOINT=https://api.freemodel.dev/v1/chat/completions
FREEMODEL_MODEL=openai-t0
FREEMODEL_TIMEOUT_SECONDS=180
FREEMODEL_RATE_LIMIT_COOLDOWN_SECONDS=300
FREEMODEL_ACCOUNT_COOLDOWN_SECONDS=3600

# Long-document translation
BACKGROUND_WORKERS=4
TRANSLATION_WORKERS=1
TRANSLATION_BATCH_SIZE=20
TRANSLATION_BATCH_CHAR_LIMIT=6000
TRANSLATION_API_RETRIES=3
TRANSLATION_RETRY_BASE_SECONDS=1
TRANSLATION_MAX_BATCH_SPLIT_DEPTH=6
TRANSLATION_PAGE_WORKERS=4
TRANSLATION_LITERARY_MIN_PAGES=80
TRANSLATION_BOOK_CONTEXT_CHAR_LIMIT=3000
TRANSLATION_BOOK_BIBLE_SAMPLE_CHARS=18000
TRANSLATION_MIN_TARGET_SCRIPT_RATIO=0.55
TRANSLATION_QUALITY_GATE_SCORE=90
# Optional provider model overrides. Leave blank to use FREEMODEL_MODEL.
TRANSLATION_DRAFT_MODEL=
TRANSLATION_EDITOR_MODEL=
TRANSLATION_REVIEWER_MODEL=
RTL_MIN_FONT_SCALE=0.55
RTL_EMERGENCY_MIN_FONT_SCALE=0.35
RTL_PAGE_MARGIN_POINTS=24
TRANSLATION_WORKER_MODE=inline
TRANSLATION_LEASE_SECONDS=300
TRANSLATION_POLL_SECONDS=2

# Portable offline translation engine (native llama.cpp; no Docker/WSL required)
LOCAL_LLM_ROOT=C:\LayoutLingo-LocalAI
LOCAL_AI_TEMP_DIR=C:\LayoutLingo-LocalAI\tmp
HF_HOME=C:\LayoutLingo-LocalAI\cache\huggingface
HF_HUB_CACHE=C:\LayoutLingo-LocalAI\cache\huggingface\hub
TRANSFORMERS_CACHE=C:\LayoutLingo-LocalAI\cache\transformers
TORCH_HOME=C:\LayoutLingo-LocalAI\cache\torch
LOCAL_LLM_ENDPOINT=http://127.0.0.1:8080/v1/chat/completions
LOCAL_LLM_MODEL=aya-expanse-8b-local
LOCAL_LLM_API_KEY=local-private-key
LOCAL_LLM_TIMEOUT_SECONDS=900

# Fast local translation engine (NLLB CTranslate2 INT8; stored in the selected folder)
FAST_TRANSLATION_MODEL_PATH=C:\LayoutLingo-LocalAI\models\nllb-200-distilled-600m-ct2-int8
FAST_TRANSLATION_DEVICE=cpu
FAST_TRANSLATION_COMPUTE_TYPE=int8
FAST_TRANSLATION_CPU_THREADS=4
FAST_TRANSLATION_BEAM_SIZE=2
# Aya review budgets for Offline Quality. These bound latency on the GTX 1050 Ti.
FAST_QUALITY_DOCUMENT_REVIEW_BUDGET=2
FAST_QUALITY_LITERARY_REVIEW_BUDGET=8
# Review chapter headings only when deterministic meaning guards detect a problem.
FAST_QUALITY_LITERARY_TITLE_REVIEW_BUDGET=12
# Keep the final literary repair pass short, cancellable, and resumable.
FINAL_LITERARY_RECOVERY_MAX_ITEMS=4
FINAL_LITERARY_RECOVERY_CONTEXT_CHARS=1800
